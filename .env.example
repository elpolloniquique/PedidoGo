# ============================================================
# PedidosGo — Variables de entorno (ejemplo)
# Copia a .env.local en la RAÍZ del monorepo (PedidoGo/).
# Las apps cargan este archivo vía next.config.ts.
# NUNCA subas secretos a GitHub.
# ============================================================

# --- Marca ---
NEXT_PUBLIC_APP_NAME=PedidosGo
NEXT_PUBLIC_APP_SHORT_NAME=PedidosGo
NEXT_PUBLIC_APP_DESCRIPTION=Plataforma inteligente de delivery para comercios y repartidores
NEXT_PUBLIC_APP_LOGO_URL=
NEXT_PUBLIC_APP_PRIMARY_COLOR=#0F766E
NEXT_PUBLIC_APP_SECONDARY_COLOR=#134E4A
NEXT_PUBLIC_APP_SUPPORT_EMAIL=soporte@pedidosgo.cl
NEXT_PUBLIC_APP_SUPPORT_PHONE=
NEXT_PUBLIC_APP_DOMAIN=pedidosgo.cl

# --- Supabase ---
# URL + anon: Project Settings → API
# SERVICE_ROLE: debe ser distinta de la anon (JWT role=service_role o clave sb_secret_...)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_never_in_browser

# --- Mapbox ---
# Público (pk.) para el navegador. Secreto (sk.) SOLO servidor / Edge Functions.
# NO uses un token pk. como secreto.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_public_token
MAPBOX_SECRET_TOKEN=sk.your_secret_token

# --- Apps ---
# admin-web: 3001 | merchant-web: 3002 | driver-pwa: 3003 | customer-tracking: 3004
