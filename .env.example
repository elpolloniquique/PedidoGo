# ============================================================
# RapideX — Variables de entorno (ejemplo)
# Copia a .env.local en la RAÍZ del monorepo.
# Las apps cargan este archivo vía next.config.ts.
# NUNCA subas secretos a GitHub.
# ============================================================

# --- Marca ---
NEXT_PUBLIC_APP_NAME=RapideX
NEXT_PUBLIC_APP_SHORT_NAME=RapideX
NEXT_PUBLIC_APP_DESCRIPTION=Plataforma inteligente de delivery para comercios y repartidores
NEXT_PUBLIC_APP_LOGO_URL=
NEXT_PUBLIC_APP_PRIMARY_COLOR=#0F766E
NEXT_PUBLIC_APP_SECONDARY_COLOR=#134E4A
NEXT_PUBLIC_APP_SUPPORT_EMAIL=soporte@rapidex.cl
NEXT_PUBLIC_APP_SUPPORT_PHONE=
NEXT_PUBLIC_APP_DOMAIN=rapidex.cl

# --- Supabase ---
# URL + anon: Project Settings → API
# SERVICE_ROLE: debe ser distinta de la anon (JWT role=service_role o clave sb_secret_...)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_never_in_browser

# --- Mapbox ---
# Público (pk.) para el navegador. Secreto (sk.) SOLO servidor.
# NO uses un token pk. como secreto. Si no tienes sk., déjalo vacío.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_public_token
MAPBOX_SECRET_TOKEN=

# --- Apps ---
# admin-web: 3001 | merchant-web: 3002 | driver-pwa: 3003 | customer-tracking: 3004

# --- E2E (opcional, Fase 15) ---
# Credenciales de un comercio de prueba para login automatizado
# E2E_MERCHANT_EMAIL=
# E2E_MERCHANT_PASSWORD=
# NEXT_PUBLIC_ADMIN_URL=https://pedidosgo-admin.vercel.app
# NEXT_PUBLIC_MERCHANT_URL=https://pedidosgo-merchant.vercel.app
# NEXT_PUBLIC_DRIVER_URL=https://pedidosgo-driver.vercel.app
# NEXT_PUBLIC_CUSTOMER_TRACKING_URL=https://pedidosgo-tracking.vercel.app
NEXT_PUBLIC_CUSTOMER_TRACKING_URL=http://localhost:3004

# --- Cron webhooks (Fase 19, merchant-web) ---
# Mismo valor en Vercel → Environment Variables del proyecto merchant.
# El cron llama /api/cron/dispatch-webhooks cada 5 min.
# CRON_SECRET=genera_un_secreto_largo_aleatorio
